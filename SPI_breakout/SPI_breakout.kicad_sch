	(text "OPC-N3 5V+ is external; tie the OPC supply ground to WisBlock GND."
		(exclude_from_sim no)
		(at 132.08 139.7 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "2b6de410-2b33-4dc4-a912-7f33a876c376")
	)
	(text "J3 is the separate OPC 5V input. Pin 1 feeds only OPC_5V_EXT on J1/J2 pin 2; pin 2 ties that supply return to WisBlock GND. It is not tied to the WisBlock 3v3 rail."
		(exclude_from_sim no)
		(at 132.08 154.94 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "626e5340-a692-4905-8708-b176c8281d04")
	)
	(text "No level shifter fitted: WisBlock, SD reader, and OPC SPI are expected to use 3.3V logic. Verify OPC SPI adapter before 5V power-up."
		(exclude_from_sim no)
		(at 132.08 149.86 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "62b519f3-fc82-426c-8668-2ed9da98e825")
	)
	(text "J1/J2 pin order: 1 GND black, 2 5V_EXT red, 3 SS green, 4 SDI blue, 5 SDO white, 6 SCK yellow. Use 3.81mm 6-pos pluggable terminals such as TJ0631030000G with a matching PCB header."
		(exclude_from_sim no)
		(at 132.08 144.78 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "f1f7e85b-6104-4018-92b2-3db11a0c5953")
	)
